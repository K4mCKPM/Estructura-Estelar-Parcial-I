curva_teorica = planck(wavs, T)

### Integrar el flujo respecto a la longitud de onda
def integral(data):
    flujo_integrado = trapezoid(data['Irradiance'], data['Min_Wave'])

    ### Flujo superficie
    F_sup = flujo_integrado * (Dist_solar/Radio_sol)**2

    ### Temperatura efectiva
    T_eff = (F_sup / sigma)**(1/4)

    print(f"""
          Flujo integrado = {flujo_integrado} W/m^2
          Flujo superficie = {F_sup} W/m^2
          Temperatura efectiva = {T_eff} K
          """)

