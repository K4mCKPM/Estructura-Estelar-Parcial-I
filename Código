### Intensidad de Planck

def planck(lambd, Temp=T, h=h, c=c, k=k):

    wav_m = lambd * 1e-9        # Se convierte nm a metros para el cálculo
    
    # Fórmula de Planck
    exp_term = np.exp((h * c) / (wav_m * k * T))
    intensity = (2 * h * c**2) / (wav_m**5 * (exp_term - 1))
    
    return intensity * 1e-9     # Se convierte de nuevo a nm

### Valores para la curva de Intensidad de planck
